# Production experience: real DeepSeek + real ElevenLabs
APP_ENV=production
SHOW_DEV_CONTROLS=false

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

USE_MOCK_CHAT=false
USE_MOCK_TTS=false
AUTO_TTS=true
ENABLE_TTS_CACHE=true
TTS_DEBUG=false
MAX_CONTEXT_TURNS=3
MAX_REPLY_EN_CHARS=320

PORT=8787
