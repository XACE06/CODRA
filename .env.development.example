# Development: full mock, no API cost
APP_ENV=development
SHOW_DEV_CONTROLS=true

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

USE_MOCK_CHAT=true
USE_MOCK_TTS=true
AUTO_TTS=false
ENABLE_TTS_CACHE=true
TTS_DEBUG=true
MAX_CONTEXT_TURNS=3
MAX_REPLY_EN_CHARS=320

PORT=8787
