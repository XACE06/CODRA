# App
APP_ENV=development
SHOW_DEV_CONTROLS=true

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Development / production cost control
USE_MOCK_CHAT=true
USE_MOCK_TTS=true
AUTO_TTS=false
ENABLE_TTS_CACHE=true
TTS_DEBUG=true
MAX_CONTEXT_TURNS=3
MAX_REPLY_EN_CHARS=320

# Local server
PORT=8787
